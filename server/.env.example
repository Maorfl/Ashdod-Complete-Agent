# Caspi Agent — server environment (copy to .env)
# רוב ההגדרות נמצאות ב-config/config.json. כאן רק סודות/override סביבתי.

# פורט ו-host (override ל-config.server). ברירת מחדל: 0.0.0.0:4000
# PORT=4000
# HOST=0.0.0.0

# Token ל-GitHub Releases (בדיקת גרסה). אופציונלי לריפו ציבורי.
# GITHUB_TOKEN=

# נתיב override לדוח Focus (במקום config.report_path)
# REPORT_PATH=\\fileserver\focus_reports\אשדוד.xlsx

# Microsoft Graph — שליחת מייל בפועל + מעקב הגעות/gatepass.
# חובה כדי ש-"אישור ושליחה" ישלח מייל אמיתי. ללא ערכים אלה המערכת רק מסמנת "נשלח".
# App registration עם הרשאות אפליקציה Mail.Send + Mail.ReadWrite (הסכמת מנהל).
# GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
# GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
# GRAPH_CLIENT_SECRET=your-client-secret-here
